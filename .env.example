# Copy to .env and fill from Firebase Console → Project settings → Your apps → Web app
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Messaging → Web Push certificates → Key pair (VAPID)
VITE_FIREBASE_VAPID_KEY=

# Server-only (Vercel / local vercel dev) — NEVER expose in VITE_*
# Paste the full Firebase service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT=
