rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isMaharaj() {
      return isSignedIn() && userDoc().data.role == 'maharaj';
    }

    function isKitchenLeader() {
      return isSignedIn() && userDoc().data.role == 'kitchen_leader';
    }

    function isRoomLeader() {
      return isSignedIn() && userDoc().data.role == 'room_leader';
    }

    function canManageVoteLocks() {
      return isAdmin() || isMaharaj() || isKitchenLeader();
    }

    /** Vote dashboard + Users/Seva management need member names. */
    function canReadAllUsers() {
      return isAdmin() || isMaharaj() || isKitchenLeader() || isRoomLeader();
    }

    function canWriteMenus() {
      return isAdmin() || isKitchenLeader();
    }

    function canWriteMenuCatalog() {
      return isAdmin() || isKitchenLeader();
    }

    function canDeleteParticipations() {
      return isAdmin() || isKitchenLeader();
    }

    function canManageSeva() {
      return isAdmin() || isRoomLeader();
    }

    function canManageLeaves() {
      return isAdmin() || isKitchenLeader() || isRoomLeader();
    }

    function canManageNotices() {
      return isAdmin() || isRoomLeader();
    }

    function canViewNoticeAnalytics() {
      return isAdmin() || isRoomLeader() || isKitchenLeader();
    }

    /**
     * Room leaders may update/delete non-admin users and may not assign admin.
     * They also cannot change their own role/status via this path.
     */
    function roomLeaderCanManageUser(userId) {
      return isRoomLeader()
        && resource.data.role != 'admin'
        && request.resource.data.role != 'admin'
        && (
          request.auth.uid != userId
          || !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
        );
    }

    function roomLeaderCanDeleteUser() {
      return isRoomLeader() && resource.data.role != 'admin';
    }

    function isApproved() {
      return isSignedIn() && (
        isAdmin() ||
        userDoc().data.status == 'approved' ||
        !('status' in userDoc().data)
      );
    }

    function slotLocked(dateId, slot) {
      return exists(/databases/$(database)/documents/voteLocks/$(dateId + '_' + slot)) &&
        get(/databases/$(database)/documents/voteLocks/$(dateId + '_' + slot)).data.locked == true;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (
        request.auth.uid == userId
        || canReadAllUsers()
        || resource.data.role == 'maharaj'
      );
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin()
        || roomLeaderCanManageUser(userId)
        || (
          isSignedIn() &&
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
        );
      allow delete: if isAdmin() || roomLeaderCanDeleteUser();
    }

    match /voteLocks/{lockId} {
      allow read: if isSignedIn();
      allow write: if canManageVoteLocks();
    }

    match /mealParticipation/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isApproved() &&
        request.resource.data.userId == request.auth.uid &&
        !slotLocked(request.resource.data.date, request.resource.data.slot);
      allow delete: if canDeleteParticipations();
    }

    match /menus/{menuId} {
      allow read: if isSignedIn();
      allow write: if canWriteMenus();
    }

    match /menuCategories/{id} {
      allow read: if isSignedIn();
      allow write: if canWriteMenuCatalog();
    }

    match /menuItems/{id} {
      allow read: if isSignedIn();
      allow write: if canWriteMenuCatalog();
    }

    match /sevaRoom/{docId} {
      allow read: if isSignedIn();
      allow write: if canManageSeva();
    }

    match /leaveEntries/{docId} {
      allow read: if isSignedIn();
      allow create: if isApproved()
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0
        && request.resource.data.period in ['morning', 'evening', 'full']
        && request.resource.data.recordedBy == request.auth.uid;
      allow update, delete: if canManageLeaves();
    }

    match /notices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if canManageNotices();

      match /receipts/{userId} {
        allow read: if canViewNoticeAnalytics()
          || (isSignedIn() && request.auth.uid == userId);
        allow create, update: if isApproved()
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid;
        allow delete: if canManageNotices();
      }
    }
  }
}
